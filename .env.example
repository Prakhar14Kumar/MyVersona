# --- FRONTEND (.env.local) ---
VITE_API_BASE_URL="https://versona-backend-api.onrender.com"
VITE_FIREBASE_API_KEY="your-client-api-key"
VITE_FIREBASE_AUTH_DOMAIN="versona.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID="versona"
VITE_SENTRY_DSN="your-sentry-react-url"

# --- BACKEND (Render Cloud Dashboard) ---
# Set inside the Render Dashboard (Do NOT put secret keys in code!)
GEMINI_API_KEY="your-gemini-key"

# Managed Redis Database Configuration
# Obtain from Upstash or AWS Elasticache (e.g. redis://default:password@xyz.upstash.io:30000)
REDIS_URL="redis://your-redis-url:6379"

# Sentry Monitoring setup
SENTRY_DSN="your-sentry-python-url"

# Firebase Admin Validation
# Convert your `serviceAccount.json` to Base64 (using `base64 serviceAccount.json > out.b64`)
# Insert that single long string here so Cloud hosting handles it safely.
FIREBASE_BASE64_CERT="<LONG_BASE64_STRING_HERE>"
