# Procfile for Railway/Render Deployment
# This file defines how to run the unified backend in production

# Web API Server (main FastAPI application)
# - Handles all HTTP requests
# - Serves both general and AI endpoints
# - Returns immediately (non-blocking)
web: uvicorn main:app --host 0.0.0.0 --port $PORT --workers 4

# High Priority Celery Worker
# - Processes critical tasks (moderation, search)
# - SLA: < 1 second
# - Concurrency: 2 workers
worker_high: celery -A modules.ai.celery_app worker -Q high_priority --loglevel=info --concurrency=2 --max-tasks-per-child=100

# Medium Priority Celery Worker
# - Processes user-facing tasks (feed ranking, recommendations)
# - SLA: 1-3 seconds
# - Concurrency: 4 workers
worker_medium: celery -A modules.ai.celery_app worker -Q medium_priority --loglevel=info --concurrency=4 --max-tasks-per-child=100

# Low Priority Celery Worker
# - Processes background tasks (career analysis, resume parsing)
# - SLA: 3-10 seconds
# - Concurrency: 4 workers
worker_low: celery -A modules.ai.celery_app worker -Q low_priority --loglevel=info --concurrency=4 --max-tasks-per-child=100

# Optional: Celery Flower (monitoring dashboard)
# Uncomment to enable: visit at https://your-app.railway.app:5555
# flower: celery -A modules.ai.celery_app flower --port=5555 --broker=$CELERY_BROKER_URL
